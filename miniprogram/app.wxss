page {
  --brand: #1565c0;
  background: #f2f3f5;
  font-family: -apple-system, "PingFang SC", "Microsoft YaHei", sans-serif;
  color: #1a1a1a;
}

.wrap { padding: 24rpx; }

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.pill {
  display: inline-block;
  padding: 4rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  background: #e3f0ff;
  color: var(--brand);
}

.btn {
  border-radius: 12rpx;
  padding: 22rpx;
  text-align: center;
  font-size: 32rpx;
  background: #eef0f3;
  color: #333;
}
.btn-primary { background: var(--brand); color: #fff; }
.btn[disabled] { opacity: 0.5; }

.row { display: flex; justify-content: space-between; align-items: center; }
.title { font-size: 34rpx; font-weight: 600; }
.muted { color: #8a8f99; font-size: 26rpx; }
.err { color: #c62828; font-size: 26rpx; margin-top: 16rpx; }

.field { margin-bottom: 22rpx; }
.field label { display: block; font-size: 26rpx; color: #555; margin-bottom: 10rpx; }
.input, picker {
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 30rpx;
}
