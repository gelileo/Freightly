<view class="wrap">
  <view class="card">
    <view class="row">
      <view class="title" style="font-size:30rpx;">{{caseInfo.shipment_bol || '（无 BOL）'}}</view>
      <text class="pill">{{statusZh}}</text>
    </view>
    <view class="muted" style="margin-top:10rpx;">{{caseInfo.issue_type || '货运问题'}}</view>
  </view>

  <view class="section-title">最新进展</view>
  <view wx:if="{{updates.length === 0}}" class="card muted">暂无更新。代理回复并审核后将在此显示。</view>
  <view wx:for="{{updates}}" wx:key="id" class="card update">
    <view class="update-body">{{item.body}}</view>
  </view>
</view>
